{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensyria.org/schemas/data-geography/governorates.schema.json",
  "title": "OpenSyria Geography Governorates",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "name",
      "aliases",
      "iso31662",
      "centroid",
      "area",
      "population",
      "externalIds",
      "sourceIds",
      "sourceStatus"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^sy-[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "name": {
        "type": "object",
        "additionalProperties": false,
        "required": ["en"],
        "properties": {
          "en": {
            "type": "string",
            "minLength": 1
          },
          "ar": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "aliases": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["value"],
          "properties": {
            "value": {
              "type": "string",
              "minLength": 1
            },
            "language": {
              "type": "string",
              "enum": ["ar", "en", "und"]
            },
            "type": {
              "type": "string",
              "enum": ["alias", "formal", "transliteration", "historical", "alternate_spelling"]
            }
          }
        }
      },
      "iso31662": {
        "type": ["string", "null"],
        "pattern": "^SY-[A-Z]{2}$"
      },
      "centroid": {
        "oneOf": [
          {
            "type": "null"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["latitude", "longitude"],
            "properties": {
              "latitude": {
                "type": "number",
                "minimum": -90,
                "maximum": 90
              },
              "longitude": {
                "type": "number",
                "minimum": -180,
                "maximum": 180
              }
            }
          }
        ]
      },
      "area": {
        "oneOf": [
          {
            "type": "null"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "unit", "sourceIds"],
            "properties": {
              "value": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "unit": {
                "type": "string",
                "enum": ["km2"]
              },
              "sourceIds": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1,
                "uniqueItems": true
              },
              "notes": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      },
      "population": {
        "oneOf": [
          {
            "type": "null"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "year", "sourceIds"],
            "properties": {
              "value": {
                "type": "integer",
                "minimum": 0
              },
              "year": {
                "type": "integer",
                "minimum": 1,
                "maximum": 9999
              },
              "date": {
                "type": "string",
                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
              },
              "sourceIds": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1,
                "uniqueItems": true
              },
              "notes": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      },
      "populationHistory": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["value", "year", "sourceIds"],
          "properties": {
            "value": {
              "type": "integer",
              "minimum": 0
            },
            "year": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9999
            },
            "date": {
              "type": "string",
              "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
            },
            "sourceIds": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "notes": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "externalIds": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "wikidata": {
            "type": "string",
            "pattern": "^Q[0-9]+$"
          },
          "geonames": {
            "type": "string",
            "pattern": "^[0-9]+$"
          },
          "geoboundaries": {
            "type": "string",
            "minLength": 1
          },
          "ochaPcode": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "sourceIds": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1,
        "uniqueItems": true
      },
      "sourceStatus": {
        "type": "string",
        "enum": ["pending_release", "seed", "released", "deprecated"]
      },
      "notes": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
